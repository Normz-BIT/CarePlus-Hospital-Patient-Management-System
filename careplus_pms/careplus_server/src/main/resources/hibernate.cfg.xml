<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE xml>
<hibernate-configuration>
    <session-factory>
        <property name="connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        <property name="connection.url">jdbc:mysql://localhost:3306/careplus_db?useSSL=false&amp;serverTimezone=UTC</property>
        <!--property name="dialect">org.hibernate.dialect.MySQLDialect</property-->
        <property name="dialect">org.hibernate.dialect.MySQLDialect</property>
		<property name="show_sql">false</property>
		<property name="format_sql">false</property>
		<property name="hbm2ddl.auto">update</property>
		<!-- mapping class="com.mcnz.jpa.examples.Player" / -->

		<!--
			The person hierarchy, listed root first. Person and Employee are both
			abstract JOINED roots, so each concrete type below them resolves through
			its parent: person then employee then the role table.
		-->
		<mapping class="com.careplus.common.model.Person"/>
		<mapping class="com.careplus.common.model.Patient"/>
		<mapping class="com.careplus.common.model.Employee"/>
		<mapping class="com.careplus.common.model.Doctor"/>
		<mapping class="com.careplus.common.model.Nurse"/>
		<mapping class="com.careplus.common.model.Receptionist"/>

		<!-- The records that hang off a person. -->
		<mapping class="com.careplus.common.model.Appointment"/>
		<mapping class="com.careplus.common.model.ChatMessage"/>
		<mapping class="com.careplus.common.model.Complaint"/>
		<mapping class="com.careplus.common.model.MedicalRecord"/>
		<mapping class="com.careplus.common.model.Payment"/>
		<mapping class="com.careplus.common.model.VitalSigns"/>
    </session-factory>
</hibernate-configuration>